# Copy to .env and fill in values. Never commit .env.

# Gemini (Google AI Studio) — required when RETAIL_AGENT_PROVIDER=gemini (default)
GOOGLE_API_KEY=

# BigQuery billing project (Application Default Credentials also required)
GCP_PROJECT_ID=
# Alternative name recognized by Google client libraries:
# GOOGLE_CLOUD_PROJECT=

# Agent defaults
RETAIL_AGENT_MODEL=gemini-2.5-flash
RETAIL_AGENT_EMBEDDING_MODEL=gemini-embedding-001
RETAIL_AGENT_PERSONA=default

# BigQuery guard defaults
BQ_DATASET_ID=bigquery-public-data.thelook_ecommerce
BQ_MAX_BYTES_BILLED=1073741824
BQ_DEFAULT_LIMIT=1000

# Optional saved reports / preferences database (defaults to ./data/reports.sqlite3)
# RETAIL_AGENT_DB_PATH=

# Optional persona directory (defaults to ./personas)
# RETAIL_AGENT_PERSONAS_DIR=

# Optional golden bucket directory (defaults to ./golden_bucket)
# GOLDEN_BUCKET_DIR=

# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=false

# Optional LLM provider selection (default: gemini)
# RETAIL_AGENT_PROVIDER=gemini
# RETAIL_AGENT_FALLBACK_PROVIDER=openrouter

# OpenRouter (when provider or fallback is openrouter)
# OPENROUTER_API_KEY=
# RETAIL_AGENT_OPENROUTER_MODEL=openrouter/auto

# Ollama (when provider or fallback is ollama)
# OLLAMA_HOST=http://localhost:11434
# RETAIL_AGENT_OLLAMA_MODEL=llama3.2
