# Optional LLM provider selection (default: gemini)
# RETAIL_AGENT_PROVIDER=gemini
# RETAIL_AGENT_FALLBACK_PROVIDER=openrouter

# OpenRouter (when provider or fallback is openrouter)
# OPENROUTER_API_KEY=
# RETAIL_AGENT_OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Ollama (when provider or fallback is ollama)
# OLLAMA_HOST=http://localhost:11434
# RETAIL_AGENT_OLLAMA_MODEL=llama3.2
